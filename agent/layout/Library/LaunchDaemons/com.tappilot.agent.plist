<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.tappilot.agent</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/bin/tappilot-agent</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/var/mobile/Library/Logs/TappilotAgent/stdout.log</string>
	<key>StandardErrorPath</key>
	<string>/var/mobile/Library/Logs/TappilotAgent/stderr.log</string>
</dict>
</plist>
